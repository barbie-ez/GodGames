<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GodGames.Mobile.ViewModels"
             xmlns:models="clr-namespace:GodGames.Mobile.Models"
             x:Class="GodGames.Mobile.Views.ChroniclesPage"
             x:DataType="vm:ChroniclesViewModel"
             Title="Chronicle"
             BackgroundColor="{StaticResource GgBg}">

    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsLoading}">
        <VerticalStackLayout Spacing="0">

            <!-- Header strip -->
            <VerticalStackLayout BackgroundColor="{StaticResource GgSurface}" Padding="20,20,20,16" Spacing="4">
                <Label Text="{Binding Champion.Name, FallbackValue='Chronicle'}"
                       FontFamily="OpenSansSemibold"
                       FontSize="24"
                       TextColor="{StaticResource GgCream}" />
                <Label Text="FULL CHRONICLE"
                       FontSize="9"
                       CharacterSpacing="4"
                       TextColor="{StaticResource GgGold}"
                       Opacity="0.6" />
                <BoxView HeightRequest="1" BackgroundColor="{StaticResource GgGold}" Margin="0,8,0,0" />
            </VerticalStackLayout>

            <!-- Stat strip -->
            <Grid BackgroundColor="{StaticResource GgSurfaceLow}"
                  ColumnDefinitions="*,*,*,*"
                  Margin="0,1,0,0">
                <VerticalStackLayout Grid.Column="0" Padding="16,14" Spacing="4">
                    <Label Text="LEVEL" FontSize="7" CharacterSpacing="2" TextColor="{StaticResource GgSilver}" Opacity="0.5" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding Champion.Level}" FontFamily="OpenSansSemibold" FontSize="20" TextColor="{StaticResource GgGold}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Padding="16,14" Spacing="4">
                    <Label Text="XP" FontSize="7" CharacterSpacing="2" TextColor="{StaticResource GgSilver}" Opacity="0.5" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding Champion.XP}" FontFamily="OpenSansSemibold" FontSize="20" TextColor="{StaticResource GgGold}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" Padding="16,14" Spacing="4">
                    <Label Text="CLASS" FontSize="7" CharacterSpacing="2" TextColor="{StaticResource GgSilver}" Opacity="0.5" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding Champion.Class}" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{StaticResource GgGold}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3" Padding="16,14" Spacing="4">
                    <Label Text="ENTRIES" FontSize="7" CharacterSpacing="2" TextColor="{StaticResource GgSilver}" Opacity="0.5" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding Entries.Count}" FontFamily="OpenSansSemibold" FontSize="20" TextColor="{StaticResource GgGold}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>

            <!-- Timeline -->
            <CollectionView ItemsSource="{Binding Entries}" SelectionMode="None" Margin="0,8,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:NarrativeEntryDto">
                        <VerticalStackLayout BackgroundColor="{StaticResource GgBg}" Padding="20,16" Spacing="8">
                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource GgSurface}" />
                            <HorizontalStackLayout Spacing="12">
                                <Border BackgroundColor="Transparent" Padding="4,2" Stroke="{StaticResource GgGold}" StrokeThickness="1">
                                    <Border.StrokeShape><Rectangle /></Border.StrokeShape>
                                    <Label Text="{Binding TickNumber, StringFormat='TICK {0}'}"
                                           FontSize="9" CharacterSpacing="2" TextColor="{StaticResource GgGold}" />
                                </Border>
                                <Label Text="{Binding CreatedAt, StringFormat='{0:g}'}"
                                       FontSize="10" TextColor="{StaticResource GgSilver}" Opacity="0.35" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding StoryText}"
                                   FontSize="13"
                                   TextColor="{StaticResource GgSilver}"
                                   Opacity="0.8"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </RefreshView>
</ContentPage>
