<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GodGames.Mobile.ViewModels"
             x:Class="GodGames.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title=""
             Shell.NavBarIsVisible="False">

    <ScrollView BackgroundColor="{StaticResource GgBg}">
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <!-- Brand -->
            <Label Text="GOD GAMES"
                   FontFamily="OpenSansSemibold"
                   FontSize="22"
                   CharacterSpacing="6"
                   TextColor="{StaticResource GgGold}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,8" />
            <Label Text="THE ASTRAL ARCHIVE"
                   FontSize="9"
                   CharacterSpacing="4"
                   TextColor="{StaticResource GgGold}"
                   Opacity="0.4"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,48" />

            <!-- Heading -->
            <Label Text="Return to the Pantheon"
                   FontFamily="OpenSansSemibold"
                   FontSize="26"
                   TextColor="{StaticResource GgCream}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,8" />
            <Label Text="The realm awaits your guidance"
                   FontSize="13"
                   TextColor="{StaticResource GgSilver}"
                   Opacity="0.6"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,40" />

            <!-- Card -->
            <Border BackgroundColor="{StaticResource GgSurfaceLow}"
                    Stroke="{StaticResource GgGold}"
                    StrokeThickness="0"
                    Padding="0">
                <Border.StrokeShape>
                    <Rectangle />
                </Border.StrokeShape>
                <!-- Gold top border via BoxView -->
                <VerticalStackLayout Spacing="0">
                    <BoxView HeightRequest="2" BackgroundColor="{StaticResource GgGold}" />
                    <VerticalStackLayout Padding="24,28,24,28" Spacing="24">

                        <!-- Error -->
                        <Border BackgroundColor="#3b000a"
                                Padding="12,10"
                                IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}">
                            <Border.StrokeShape><Rectangle /></Border.StrokeShape>
                            <Border Stroke="{StaticResource GgError}" StrokeThickness="0" Padding="0">
                                <Border.StrokeShape><Rectangle /></Border.StrokeShape>
                                <Label Text="{Binding ErrorMessage}"
                                       TextColor="{StaticResource GgError}"
                                       FontSize="12" />
                            </Border>
                        </Border>

                        <!-- Email -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="DIVINE IDENTIFIER"
                                   FontSize="9"
                                   CharacterSpacing="3"
                                   TextColor="{StaticResource GgOutline}" />
                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource GgOutlineVar}" />
                            <Entry Text="{Binding Email}"
                                   Placeholder="your celestial essence"
                                   Keyboard="Email"
                                   ReturnType="Next" />
                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource GgOutlineVar}" />
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="ASTRAL CIPHER"
                                   FontSize="9"
                                   CharacterSpacing="3"
                                   TextColor="{StaticResource GgOutline}" />
                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource GgOutlineVar}" />
                            <Entry Text="{Binding Password}"
                                   Placeholder="••••••••"
                                   IsPassword="True"
                                   ReturnType="Done"
                                   ReturnCommand="{Binding LoginCommand}" />
                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource GgOutlineVar}" />
                        </VerticalStackLayout>

                        <!-- Submit -->
                        <Button Text="{Binding IsBusy, Converter={StaticResource BusyToTextConverter}, ConverterParameter='ENTERING THE REALM…|ENTER THE REALM'}"
                                Command="{Binding LoginCommand}"
                                IsEnabled="{Binding IsNotBusy}"
                                FontFamily="OpenSansSemibold"
                                FontSize="11"
                                CharacterSpacing="3"
                                BackgroundColor="{StaticResource GgGold}"
                                TextColor="{StaticResource GgOnGold}"
                                CornerRadius="0"
                                Padding="0,18"
                                Margin="0,8,0,0" />

                        <!-- Footer -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                            <Label Text="New to the Pantheon?"
                                   FontSize="12"
                                   TextColor="{StaticResource GgSilver}"
                                   Opacity="0.5" />
                            <Label Text="Inscribe Your Name"
                                   FontSize="12"
                                   TextColor="{StaticResource GgGold}"
                                   TextDecorations="Underline">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
