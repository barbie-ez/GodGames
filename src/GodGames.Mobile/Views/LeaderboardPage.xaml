<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GodGames.Mobile.ViewModels"
             xmlns:models="clr-namespace:GodGames.Mobile.Models"
             x:Class="GodGames.Mobile.Views.LeaderboardPage"
             x:DataType="vm:LeaderboardViewModel"
             Title="Leaderboard"
             BackgroundColor="{StaticResource GgBg}">

    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsLoading}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <VerticalStackLayout BackgroundColor="{StaticResource GgSurface}" Padding="20,20,20,16" Spacing="4">
                <Label Text="Leaderboard"
                       FontFamily="OpenSansSemibold"
                       FontSize="24"
                       TextColor="{StaticResource GgCream}" />
                <BoxView HeightRequest="1" BackgroundColor="{StaticResource GgGold}" Margin="0,8,0,0" />
            </VerticalStackLayout>

            <!-- Table header -->
            <Grid BackgroundColor="{StaticResource GgSurfaceMid}"
                  ColumnDefinitions="44,*,60,50,60,60"
                  Padding="0,12" Margin="0,1,0,0">
                <Label Grid.Column="0" Text="#" FontSize="8" CharacterSpacing="2" TextColor="{StaticResource GgGold}" HorizontalTextAlignment="Center" />
                <Label Grid.Column="1" Text="NAME" FontSize="8" CharacterSpacing="2" TextColor="{StaticResource GgGold}" Padding="0,0,0,0" />
                <Label Grid.Column="2" Text="CLASS" FontSize="8" CharacterSpacing="2" TextColor="{StaticResource GgGold}" HorizontalTextAlignment="Center" />
                <Label Grid.Column="3" Text="LVL" FontSize="8" CharacterSpacing="2" TextColor="{StaticResource GgGold}" HorizontalTextAlignment="Center" />
                <Label Grid.Column="4" Text="XP" FontSize="8" CharacterSpacing="2" TextColor="{StaticResource GgGold}" HorizontalTextAlignment="Center" />
                <Label Grid.Column="5" Text="BIOME" FontSize="8" CharacterSpacing="2" TextColor="{StaticResource GgGold}" HorizontalTextAlignment="Center" />
            </Grid>

            <!-- Empty state -->
            <Label Text="No champions have entered the world yet."
                   IsVisible="{Binding Entries.Count, Converter={StaticResource ZeroToBoolConverter}}"
                   FontSize="13" TextColor="{StaticResource GgSilver}" Opacity="0.4"
                   HorizontalTextAlignment="Center" Padding="20,60" />

            <!-- Rows -->
            <CollectionView ItemsSource="{Binding Entries}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:LeaderboardEntryDto">
                        <Grid ColumnDefinitions="44,*,60,50,60,60"
                              BackgroundColor="{StaticResource GgSurface}"
                              Margin="0,0,0,1"
                              Padding="0,14">
                            <Label Grid.Column="0"
                                   Text="{Binding Rank}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{StaticResource GgGold}"
                                   Opacity="0.6"
                                   HorizontalTextAlignment="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding Name}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{StaticResource GgCream}" />
                            <Label Grid.Column="2"
                                   Text="{Binding Class}"
                                   FontSize="10"
                                   TextColor="{StaticResource GgSilver}"
                                   Opacity="0.6"
                                   HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3"
                                   Text="{Binding Level}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{StaticResource GgCream}"
                                   HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4"
                                   Text="{Binding XP}"
                                   FontSize="12"
                                   TextColor="{StaticResource GgSilver}"
                                   Opacity="0.7"
                                   HorizontalTextAlignment="Center" />
                            <Label Grid.Column="5"
                                   Text="{Binding Biome}"
                                   FontSize="10"
                                   TextColor="{StaticResource GgSilver}"
                                   Opacity="0.5"
                                   HorizontalTextAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </RefreshView>
</ContentPage>
