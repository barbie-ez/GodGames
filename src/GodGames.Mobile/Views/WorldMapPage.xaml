<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GodGames.Mobile.ViewModels"
             xmlns:models="clr-namespace:GodGames.Mobile.Models"
             x:Class="GodGames.Mobile.Views.WorldMapPage"
             x:DataType="vm:WorldMapViewModel"
             Title="World Map"
             BackgroundColor="{StaticResource GgBg}">

    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsLoading}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <VerticalStackLayout BackgroundColor="{StaticResource GgSurface}" Padding="20,20,20,16" Spacing="4">
                <Label Text="World Map"
                       FontFamily="OpenSansSemibold"
                       FontSize="24"
                       TextColor="{StaticResource GgCream}" />
                <BoxView HeightRequest="1" BackgroundColor="{StaticResource GgGold}" Margin="0,8,0,0" />
            </VerticalStackLayout>

            <!-- Selected region detail -->
            <VerticalStackLayout BackgroundColor="{StaticResource GgSurfaceLow}"
                                 Padding="20,16" Spacing="8"
                                 IsVisible="{Binding SelectedRegion, Converter={StaticResource IsNotNullConverter}}">
                <HorizontalStackLayout Spacing="12" Margin="0,0,0,4">
                    <Label Text="{Binding SelectedRegion.Name}"
                           FontFamily="OpenSansSemibold"
                           FontSize="18"
                           TextColor="{StaticResource GgCream}" />
                    <Border BackgroundColor="#1a1500" Padding="5,2" StrokeThickness="0">
                        <Border.StrokeShape><Rectangle /></Border.StrokeShape>
                        <Label Text="{Binding SelectedRegion.Biome}"
                               FontSize="9" CharacterSpacing="2" TextColor="{StaticResource GgGold}" />
                    </Border>
                </HorizontalStackLayout>
                <Label Text="{Binding SelectedRegion.Description}"
                       FontSize="12" TextColor="{StaticResource GgSilver}" Opacity="0.65" LineBreakMode="WordWrap" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="1" Margin="0,4,0,0">
                    <VerticalStackLayout Grid.Column="0" BackgroundColor="{StaticResource GgSurfaceHigh}" Padding="12,10" Spacing="3">
                        <Label Text="DIFFICULTY" FontSize="7" CharacterSpacing="2" TextColor="{StaticResource GgSilver}" Opacity="0.5" />
                        <Label Text="{Binding SelectedRegion.DifficultyRating, StringFormat='{0} / 10'}" FontFamily="OpenSansSemibold" FontSize="16" TextColor="{StaticResource GgGold}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" BackgroundColor="{StaticResource GgSurfaceHigh}" Padding="12,10" Spacing="3">
                        <Label Text="MIN LEVEL" FontSize="7" CharacterSpacing="2" TextColor="{StaticResource GgSilver}" Opacity="0.5" />
                        <Label Text="{Binding SelectedRegion.MinLevelRequired}" FontFamily="OpenSansSemibold" FontSize="16" TextColor="{StaticResource GgGold}" />
                    </VerticalStackLayout>
                </Grid>
                <Label Text="{Binding SelectedRegion.ActiveEventTypes}"
                       FontSize="11" TextColor="{StaticResource GgSilver}" Opacity="0.5" Margin="0,4,0,0" />
            </VerticalStackLayout>

            <!-- Region list -->
            <Label Text="TAP A REGION TO EXPLORE"
                   FontSize="8"
                   CharacterSpacing="3"
                   TextColor="{StaticResource GgOutline}"
                   Opacity="0.5"
                   Padding="20,16,20,8" />

            <CollectionView ItemsSource="{Binding Regions}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedRegion}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:WorldRegionDto">
                        <Grid ColumnDefinitions="4,*,Auto" BackgroundColor="{StaticResource GgSurface}" Margin="0,0,0,1" Padding="0,14,16,14">
                            <BoxView Grid.Column="0" BackgroundColor="{StaticResource GgOutlineVar}" />
                            <VerticalStackLayout Grid.Column="1" Padding="16,0" Spacing="3">
                                <Label Text="{Binding Name}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="14"
                                       TextColor="{StaticResource GgCream}" />
                                <Label Text="{Binding Biome}"
                                       FontSize="10"
                                       CharacterSpacing="1"
                                       TextColor="{StaticResource GgSilver}"
                                       Opacity="0.5" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="{Binding DifficultyRating, StringFormat='⬥{0}'}"
                                   FontSize="12"
                                   TextColor="{StaticResource GgGold}"
                                   Opacity="0.6"
                                   VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </RefreshView>
</ContentPage>
