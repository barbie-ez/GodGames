<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GodGames.Mobile.ViewModels"
             x:Class="GodGames.Mobile.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title=""
             Shell.NavBarIsVisible="False">

    <ScrollView BackgroundColor="{StaticResource GgBg}">
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <Label Text="GOD GAMES"
                   FontFamily="OpenSansSemibold"
                   FontSize="22"
                   CharacterSpacing="6"
                   TextColor="{StaticResource GgGold}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,8" />
            <Label Text="THE ASTRAL ARCHIVE"
                   FontSize="9"
                   CharacterSpacing="4"
                   TextColor="{StaticResource GgGold}"
                   Opacity="0.4"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,48" />

            <Label Text="Become a God"
                   FontFamily="OpenSansSemibold"
                   FontSize="26"
                   TextColor="{StaticResource GgCream}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,8" />
            <Label Text="Enter your divine credentials"
                   FontSize="13"
                   TextColor="{StaticResource GgSilver}"
                   Opacity="0.6"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,40" />

            <!-- Success state -->
            <VerticalStackLayout IsVisible="{Binding Success}" Spacing="16" Margin="0,0,0,24">
                <Border BackgroundColor="#1a1500" Padding="16,14">
                    <Border.StrokeShape><Rectangle /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <BoxView HeightRequest="2" BackgroundColor="{StaticResource GgGold}" />
                        <Label Text="Account created. Sign in to enter the realm."
                               TextColor="{StaticResource GgCream}"
                               FontSize="13"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Sign In"
                               FontSize="13"
                               TextColor="{StaticResource GgGold}"
                               TextDecorations="Underline"
                               HorizontalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- Form -->
            <Border BackgroundColor="{StaticResource GgSurfaceLow}"
                    Padding="0"
                    IsVisible="{Binding Success, Converter={StaticResource InverseBoolConverter}}">
                <Border.StrokeShape><Rectangle /></Border.StrokeShape>
                <VerticalStackLayout Spacing="0">
                    <BoxView HeightRequest="2" BackgroundColor="{StaticResource GgGold}" />
                    <VerticalStackLayout Padding="24,28,24,28" Spacing="24">

                        <Border BackgroundColor="#3b000a"
                                Padding="12,10"
                                IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}">
                            <Border.StrokeShape><Rectangle /></Border.StrokeShape>
                            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource GgError}" FontSize="12" />
                        </Border>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="ASTRAL RESONANCE (EMAIL)" FontSize="9" CharacterSpacing="3" TextColor="{StaticResource GgOutline}" />
                            <Entry Text="{Binding Email}" Placeholder="essence@void.com" Keyboard="Email" ReturnType="Next" />
                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource GgOutlineVar}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="SECRET SIGIL (PASSWORD)" FontSize="9" CharacterSpacing="3" TextColor="{StaticResource GgOutline}" />
                            <Entry Text="{Binding Password}" Placeholder="••••••••" IsPassword="True" ReturnType="Done" ReturnCommand="{Binding RegisterCommand}" />
                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource GgOutlineVar}" />
                        </VerticalStackLayout>

                        <Button Text="{Binding IsBusy, Converter={StaticResource BusyToTextConverter}, ConverterParameter='ASCENDING…|ASCEND'}"
                                Command="{Binding RegisterCommand}"
                                IsEnabled="{Binding IsNotBusy}"
                                FontFamily="OpenSansSemibold"
                                FontSize="11"
                                CharacterSpacing="3"
                                BackgroundColor="{StaticResource GgGold}"
                                TextColor="{StaticResource GgOnGold}"
                                CornerRadius="0"
                                Padding="0,18"
                                Margin="0,8,0,0" />

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                            <Label Text="Already immortal?" FontSize="12" TextColor="{StaticResource GgSilver}" Opacity="0.5" />
                            <Label Text="Recall Essence" FontSize="12" TextColor="{StaticResource GgGold}" TextDecorations="Underline">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
