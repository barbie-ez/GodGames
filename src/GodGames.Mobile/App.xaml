<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:GodGames.Mobile.Converters"
             x:Class="GodGames.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Value converters -->
            <converters:BusyToTextConverter x:Key="BusyToTextConverter" />
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:PercentToWidthConverter x:Key="PercentToWidthConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:ZeroToBoolConverter x:Key="ZeroToBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
