@inject AuthService Auth
@inject NavigationManager Nav

<nav class="gg-sidebar @(_collapsed ? "gg-sidebar--collapsed" : "")">
    <div class="gg-sidebar__brand">
        <h1 class="gg-sidebar__title">God Games</h1>
        <p class="gg-sidebar__subtitle">The Astral Archive</p>
    </div>

    <button class="gg-sidebar__toggle" @onclick="ToggleSidebar" title="Toggle navigation">
        <span class="material-symbols-outlined">menu</span>
    </button>

    <div class="gg-sidebar__nav">
        <AuthorizeView>
            <Authorized>
                <NavLink class="gg-nav-item" href="" Match="NavLinkMatch.All">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span class="gg-nav-item__label">Dashboard</span>
                </NavLink>
                <NavLink class="gg-nav-item" href="/champion/history">
                    <span class="material-symbols-outlined">auto_stories</span>
                    <span class="gg-nav-item__label">Chronicle</span>
                </NavLink>
                <NavLink class="gg-nav-item" href="/world-map">
                    <span class="material-symbols-outlined">public</span>
                    <span class="gg-nav-item__label">World Map</span>
                </NavLink>
                <NavLink class="gg-nav-item" href="/leaderboard">
                    <span class="material-symbols-outlined">leaderboard</span>
                    <span class="gg-nav-item__label">Leaderboard</span>
                </NavLink>
            </Authorized>
            <NotAuthorized>
                <NavLink class="gg-nav-item" href="/leaderboard">
                    <span class="material-symbols-outlined">leaderboard</span>
                    <span class="gg-nav-item__label">Leaderboard</span>
                </NavLink>
                <NavLink class="gg-nav-item" href="/login">
                    <span class="material-symbols-outlined">login</span>
                    <span class="gg-nav-item__label">Sign In</span>
                </NavLink>
                <NavLink class="gg-nav-item" href="/register">
                    <span class="material-symbols-outlined">person_add</span>
                    <span class="gg-nav-item__label">Register</span>
                </NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </div>

    <div class="gg-sidebar__footer">
        <AuthorizeView>
            <Authorized>
                <button class="gg-signout-btn" @onclick="Logout">
                    <span class="material-symbols-outlined">logout</span>
                    <span class="gg-nav-item__label">Sign Out</span>
                </button>
            </Authorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    private bool _collapsed = true;
    private void ToggleSidebar() => _collapsed = !_collapsed;

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}
