@page "/login"
@layout AuthLayout
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Sign In — God Games</PageTitle>

<div class="text-center mb-10">
    <div class="auth-brand-icon">
        <span class="material-symbols-outlined">auto_awesome</span>
    </div>
    <h1 class="auth-heading">Return to the Pantheon</h1>
    <p class="auth-subheading">The realm awaits your guidance</p>
</div>

<div class="auth-card">
    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="auth-alert auth-alert--error">@_error</div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />
        <div class="auth-field-group">
            <div class="auth-field">
                <label class="auth-label" for="login-email">Divine Identifier</label>
                <div class="auth-input-wrap">
                    <span class="material-symbols-outlined auth-input-icon">alternate_email</span>
                    <InputText @bind-Value="_model.Email" class="input-altar auth-input" id="login-email"
                               type="email" placeholder="your celestial essence" autocomplete="email" />
                </div>
            </div>

            <div class="auth-field">
                <div class="auth-field-header">
                    <label class="auth-label" for="login-password">Astral Cipher</label>
                </div>
                <div class="auth-input-wrap">
                    <span class="material-symbols-outlined auth-input-icon">key</span>
                    <InputText @bind-Value="_model.Password" class="input-altar auth-input" id="login-password"
                               type="password" placeholder="••••••••" autocomplete="current-password" />
                </div>
            </div>
        </div>

        <div class="auth-cta">
            <button type="submit" class="solar-flare auth-submit" disabled="@_loading">
                @if (_loading)
                {
                    <span>Entering the Realm…</span>
                }
                else
                {
                    <span>Enter the Realm</span>
                    <span class="material-symbols-outlined">arrow_forward</span>
                }
            </button>
        </div>
    </EditForm>

    <div class="auth-footer-link">
        New to the Pantheon? <a href="/register">Inscribe Your Name</a>
    </div>
</div>

@code {
    private readonly LoginFormModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        _loading = true;
        _error = null;
        var ok = await Auth.LoginAsync(_model.Email, _model.Password);
        _loading = false;

        if (ok) Nav.NavigateTo("/");
        else _error = "Invalid email or password.";
    }

    private class LoginFormModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
