@page "/register"
@layout AuthLayout
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Become a God — God Games</PageTitle>

<div class="text-center mb-10">
    <div class="auth-brand-icon">
        <span class="material-symbols-outlined">auto_awesome</span>
    </div>
    <h1 class="auth-heading">Become a God</h1>
    <p class="auth-subheading">Enter your divine credentials</p>
</div>

<div class="auth-card">
    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="auth-alert auth-alert--error">@_error</div>
    }
    @if (_success)
    {
        <div class="auth-alert auth-alert--success">
            Account created. <a href="/login">Sign in to enter the realm</a>
        </div>
    }
    else
    {
        <EditForm Model="_model" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />
            <div class="auth-field-group">
                <div class="auth-field">
                    <label class="auth-label">Astral Resonance (Email)</label>
                    <div class="auth-input-wrap">
                        <span class="material-symbols-outlined auth-input-icon">alternate_email</span>
                        <InputText @bind-Value="_model.Email" class="input-altar auth-input"
                                   type="email" placeholder="essence@void.com" autocomplete="email" />
                    </div>
                </div>

                <div class="auth-field">
                    <label class="auth-label">Secret Sigil (Password)</label>
                    <div class="auth-input-wrap">
                        <span class="material-symbols-outlined auth-input-icon">key</span>
                        <InputText @bind-Value="_model.Password" class="input-altar auth-input"
                                   type="password" placeholder="••••••••" autocomplete="new-password" />
                    </div>
                </div>
            </div>

            <div class="auth-cta">
                <button type="submit" class="solar-flare auth-submit" disabled="@_loading">
                    @(_loading ? "Ascending…" : "Ascend")
                </button>
            </div>
        </EditForm>

        <div class="auth-footer-link">
            Already an immortal? <a href="/login">Recall Essence</a>
        </div>
    }
</div>

<p class="auth-footnote">"The stars are but witnesses to your becoming."</p>

@code {
    private readonly RegisterFormModel _model = new();
    private string? _error;
    private bool _loading;
    private bool _success;

    private async Task HandleRegister()
    {
        _loading = true;
        _error = null;
        var error = await Auth.RegisterAsync(_model.Email, _model.Password);
        _loading = false;

        if (error is null) _success = true;
        else _error = error;
    }

    private class RegisterFormModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
